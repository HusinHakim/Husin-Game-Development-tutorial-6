[gd_scene format=3]

[ext_resource type="FontFile" uid="uid://bpaegc6lsovqt" path="res://assets/Fonts/CC Wild Words Roman.ttf" id="1_font"]
[ext_resource type="Script" uid="uid://dqi5l4b1tgsuv" path="res://scripts/link_button.gd" id="2_script"]

[node name="StageSelect" type="ColorRect"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
