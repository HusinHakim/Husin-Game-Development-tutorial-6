[connection signal="pressed" from="VBoxContainer/Level1Button" to="VBoxContainer/Level1Button" method="_on_New_Game_pressed"]
[connection signal="pressed" from="VBoxContainer/Level2Button" to="VBoxContainer/Level2Button" method="_on_New_Game_pressed"]
